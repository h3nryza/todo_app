# ===========================================
# What I Would Forget — Environment Variables
# ===========================================
# Copy this file to .env and fill in values
# NEVER commit .env to git

# App
APP_NAME=What I Would Forget
NODE_ENV=development
API_PORT=3001
WEB_PORT=5173

# Database (PostgreSQL)
DATABASE_URL=postgresql://remindme:remindme@localhost:5432/remindme?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT Auth
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-string
JWT_REFRESH_EXPIRES_IN=7d

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# OAuth — Apple
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Web Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@wiwf.app

# Firebase Cloud Messaging (Phase 2+)
# FCM_PROJECT_ID=
# FCM_PRIVATE_KEY=
# FCM_CLIENT_EMAIL=

# Sentry (optional)
SENTRY_DSN=

# Cors
CORS_ORIGIN=http://localhost:5173
